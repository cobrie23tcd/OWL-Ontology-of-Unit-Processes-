@prefix : <http://www.semanticweb.org/obrienchrist/ontologies/2026/5/NewContractsOntology/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.semanticweb.org/obrienchrist/ontologies/2026/5/NewContractsOntology/> .

<http://www.semanticweb.org/obrienchrist/ontologies/2026/5/new-contract-ontology> rdf:type owl:Ontology ;
                                                                                   rdfs:comment "Models the new student internship contract process at Infineon Technologies performed by Student Admin 1. Combines BPMN process structure (activities, sequence flows, events) with ontology data (roles, data stores, task durations). Empirical task duration data sourced from NewContractStepsTimes.csv (MM:SS format), observed on 30.07.2024 and 16.12.2025 by Stud_Admin_1." ;
                                                                                   rdfs:label "New Student Contract Process Ontology" .

#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/obrienchrist/ontologies/2026/5/new-contract-ontology/hasSequenceFlow
<http://www.semanticweb.org/obrienchrist/ontologies/2026/5/new-contract-ontology/hasSequenceFlow> rdf:type owl:ObjectProperty ;
                                                                                                  rdfs:domain <http://www.semanticweb.org/obrienchrist/ontologies/2026/5/new-contract-ontology/FlowNode> ;
                                                                                                  rdfs:range <http://www.semanticweb.org/obrienchrist/ontologies/2026/5/new-contract-ontology/SequenceFlow> ;
                                                                                                  rdfs:comment "Links a FlowNode to its outgoing SequenceFlow connector." ;
                                                                                                  rdfs:label "has Sequence Flow" .


###  http://www.semanticweb.org/obrienchrist/ontologies/2026/5/new-contract-ontology/hasSubProcess
<http://www.semanticweb.org/obrienchrist/ontologies/2026/5/new-contract-ontology/hasSubProcess> rdf:type owl:ObjectProperty ;
                                                                                                rdfs:range <http://www.semanticweb.org/obrienchrist/ontologies/2026/5/new-contract-ontology/UserTask> ;
                                                                                                rdfs:comment "Links a parent UserTask to one of its constituent sub-tasks." ;
                                                                                                rdfs:label "has Sub Process" .


###  http://www.semanticweb.org/obrienchrist/ontologies/2026/5/new-contract-ontology/isPerformedBy
<http://www.semanticweb.org/obrienchrist/ontologies/2026/5/new-contract-ontology/isPerformedBy> rdf:type owl:ObjectProperty ;
                                                                                                rdfs:domain <http://www.semanticweb.org/obrienchrist/ontologies/2026/5/new-contract-ontology/UserTask> ;
                                                                                                rdfs:range <http://www.semanticweb.org/obrienchrist/ontologies/2026/5/new-contract-ontology/Role> ;
                                                                                                rdfs:comment "Links a UserTask to the Role that performs it." ;
                                                                                                rdfs:label "is Performed By" .


###  http://www.semanticweb.org/obrienchrist/ontologies/2026/5/new-contract-ontology/triggeredBy
<http://www.semanticweb.org/obrienchrist/ontologies/2026/5/new-contract-ontology/triggeredBy> rdf:type owl:ObjectProperty ;
                                                                                              rdfs:domain <http://www.semanticweb.org/obrienchrist/ontologies/2026/5/new-contract-ontology/FlowNode> ;
                                                                                              rdfs:range <http://www.semanticweb.org/obrienchrist/ontologies/2026/5/new-contract-ontology/FlowNode> ;
                                                                                              rdfs:comment "Links a FlowNode to the FlowNode that precedes it in the process." ;
                                                                                              rdfs:label "triggered By" .


###  http://www.semanticweb.org/obrienchrist/ontologies/2026/5/new-contract-ontology/usesDataStore
<http://www.semanticweb.org/obrienchrist/ontologies/2026/5/new-contract-ontology/usesDataStore> rdf:type owl:ObjectProperty ;
                                                                                                rdfs:domain <http://www.semanticweb.org/obrienchrist/ontologies/2026/5/new-contract-ontology/UserTask> ;
                                                                                                rdfs:range <http://www.semanticweb.org/obrienchrist/ontologies/2026/5/new-contract-ontology/DataStores> ;
                                                                                                rdfs:comment "Links a UserTask to a DataStore it reads from or writes to." ;
                                                                                                rdfs:label "uses Data Store" .


#################################################################
#    Data properties
#################################################################

###  http://www.semanticweb.org/obrienchrist/ontologies/2026/5/new-contract-ontology/hasDurationMinutes
<http://www.semanticweb.org/obrienchrist/ontologies/2026/5/new-contract-ontology/hasDurationMinutes> rdf:type owl:DatatypeProperty ;
                                                                                                     rdfs:domain <http://www.semanticweb.org/obrienchrist/ontologies/2026/5/new-contract-ontology/UserTask> ;
                                                                                                     rdfs:range xsd:decimal ;
                                                                                                     rdfs:comment "Total empirically measured duration of this process step in decimal minutes, observed by Stud_Admin_1. Values are converted from MM:SS entries in NewContractStepsTimes.csv (TimeHoursMinutes column) using total_seconds / 60. Only leaf classes corresponding to a CSV row carry a value." ;
                                                                                                     rdfs:label "has Duration in Minutes" .


#################################################################
#    Classes
#################################################################

###  http://www.semanticweb.org/obrienchrist/ontologies/2026/5/new-contract-ontology/DataStores
<http://www.semanticweb.org/obrienchrist/ontologies/2026/5/new-contract-ontology/DataStores> rdf:type owl:Class ;
                                                                                             rdfs:comment "BPMN Data Store - persistent information repository accessed by UserTasks." ;
                                                                                             rdfs:label "Data Stores" .


###  http://www.semanticweb.org/obrienchrist/ontologies/2026/5/new-contract-ontology/EndEvent
<http://www.semanticweb.org/obrienchrist/ontologies/2026/5/new-contract-ontology/EndEvent> rdf:type owl:Class ;
                                                                                           rdfs:subClassOf <http://www.semanticweb.org/obrienchrist/ontologies/2026/5/new-contract-ontology/FlowNode> ;
                                                                                           rdfs:comment "BPMN End Event - terminates a process path." ;
                                                                                           rdfs:label "End Event" .


###  http://www.semanticweb.org/obrienchrist/ontologies/2026/5/new-contract-ontology/EndOfNewContractProcess
<http://www.semanticweb.org/obrienchrist/ontologies/2026/5/new-contract-ontology/EndOfNewContractProcess> rdf:type owl:Class ;
                                                                                                          rdfs:subClassOf <http://www.semanticweb.org/obrienchrist/ontologies/2026/5/new-contract-ontology/EndEvent> .


###  http://www.semanticweb.org/obrienchrist/ontologies/2026/5/new-contract-ontology/FlowNode
<http://www.semanticweb.org/obrienchrist/ontologies/2026/5/new-contract-ontology/FlowNode> rdf:type owl:Class ;
                                                                                           rdfs:comment "Abstract BPMN Flow Node - common superclass of UserTask, StartEvent, IntermediateEvent and EndEvent. Used as domain/range of triggeredBy and hasSequenceFlow to avoid anonymous union nodes." ;
                                                                                           rdfs:label "Flow Node" .


###  http://www.semanticweb.org/obrienchrist/ontologies/2026/5/new-contract-ontology/IntermediateEvent
<http://www.semanticweb.org/obrienchrist/ontologies/2026/5/new-contract-ontology/IntermediateEvent> rdf:type owl:Class ;
                                                                                                    rdfs:subClassOf <http://www.semanticweb.org/obrienchrist/ontologies/2026/5/new-contract-ontology/FlowNode> ;
                                                                                                    rdfs:comment "BPMN Intermediate Event - happens between start and end of a process." ;
                                                                                                    rdfs:label "Intermediate Event" .


