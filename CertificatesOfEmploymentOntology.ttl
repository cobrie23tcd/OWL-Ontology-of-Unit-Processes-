@prefix : <http://www.semanticweb.org/obrienchrist/ontologies/2026/5/Certfiicate-of-Employment-Ontology/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.semanticweb.org/obrienchrist/ontologies/2026/5/Certfiicate-of-Employment-Ontology/> .

<http://www.semanticweb.org/obrienchrist/ontologies/2026/5/Certificate-of-Employment-Ontology> rdf:type owl:Ontology ;
                                                                                                rdfs:comment "Models the Certificate of Employment (CoE) request process managed by the admin team of Infineon's Supply Chain Innovation department, as part of the student offboarding procedure. The process begins one month before the end of the student contract, when the operator emails the departing student to request a list of completed tasks; it continues with preparation of the task list, receiving the task list, creation of the supervisor evaluation file, and a confirmation email with certificate request guidelines. Combines BPMN process structure (user tasks, sequence flows, events) with ontology data (roles, data stores, task durations). Empirical task duration data sourced from CoE_RPT.csv (MM:SS format), converted to decimal minutes." ;
                                                                                                rdfs:label "Certificate of Employment Process Ontology" .

#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/obrienchrist/ontologies/2026/5/Certificate-of-Employment-Ontology/hasSequenceFlow
<http://www.semanticweb.org/obrienchrist/ontologies/2026/5/Certificate-of-Employment-Ontology/hasSequenceFlow> rdf:type owl:ObjectProperty ;
                                                                                                               rdfs:domain <http://www.semanticweb.org/obrienchrist/ontologies/2026/5/Certificate-of-Employment-Ontology/FlowNode> ;
                                                                                                               rdfs:range <http://www.semanticweb.org/obrienchrist/ontologies/2026/5/Certificate-of-Employment-Ontology/SequenceFlow> ;
                                                                                                               rdfs:comment "Links a FlowNode to its outgoing SequenceFlow connector." ;
                                                                                                               rdfs:label "has Sequence Flow" .


###  http://www.semanticweb.org/obrienchrist/ontologies/2026/5/Certificate-of-Employment-Ontology/hasSubProcess
<http://www.semanticweb.org/obrienchrist/ontologies/2026/5/Certificate-of-Employment-Ontology/hasSubProcess> rdf:type owl:ObjectProperty ;
                                                                                                             rdfs:domain <http://www.semanticweb.org/obrienchrist/ontologies/2026/5/Certificate-of-Employment-Ontology/UserTask> ;
                                                                                                             rdfs:range <http://www.semanticweb.org/obrienchrist/ontologies/2026/5/Certificate-of-Employment-Ontology/UserTask> ;
                                                                                                             rdfs:comment "Links a parent UserTask to one of its constituent sub-tasks." ;
                                                                                                             rdfs:label "has Sub Process" .


###  http://www.semanticweb.org/obrienchrist/ontologies/2026/5/Certificate-of-Employment-Ontology/isPerformedBy
<http://www.semanticweb.org/obrienchrist/ontologies/2026/5/Certificate-of-Employment-Ontology/isPerformedBy> rdf:type owl:ObjectProperty ;
                                                                                                             rdfs:domain <http://www.semanticweb.org/obrienchrist/ontologies/2026/5/Certificate-of-Employment-Ontology/UserTask> ;
                                                                                                             rdfs:range <http://www.semanticweb.org/obrienchrist/ontologies/2026/5/Certificate-of-Employment-Ontology/Role> ;
                                                                                                             rdfs:comment "Links a UserTask to the Role that performs it." ;
                                                                                                             rdfs:label "is Performed By" .


###  http://www.semanticweb.org/obrienchrist/ontologies/2026/5/Certificate-of-Employment-Ontology/triggeredBy
<http://www.semanticweb.org/obrienchrist/ontologies/2026/5/Certificate-of-Employment-Ontology/triggeredBy> rdf:type owl:ObjectProperty ;
                                                                                                           rdfs:domain <http://www.semanticweb.org/obrienchrist/ontologies/2026/5/Certificate-of-Employment-Ontology/FlowNode> ;
                                                                                                           rdfs:range <http://www.semanticweb.org/obrienchrist/ontologies/2026/5/Certificate-of-Employment-Ontology/FlowNode> ;
                                                                                                           rdfs:comment "Links a FlowNode to the FlowNode that precedes it in the process." ;
                                                                                                           rdfs:label "triggered By" .


###  http://www.semanticweb.org/obrienchrist/ontologies/2026/5/Certificate-of-Employment-Ontology/usesDataStore
<http://www.semanticweb.org/obrienchrist/ontologies/2026/5/Certificate-of-Employment-Ontology/usesDataStore> rdf:type owl:ObjectProperty ;
                                                                                                             rdfs:domain <http://www.semanticweb.org/obrienchrist/ontologies/2026/5/Certificate-of-Employment-Ontology/UserTask> ;
                                                                                                             rdfs:range <http://www.semanticweb.org/obrienchrist/ontologies/2026/5/Certificate-of-Employment-Ontology/DataStores> ;
                                                                                                             rdfs:comment "Links a UserTask to a DataStore it reads from or writes to." ;
                                                                                                             rdfs:label "uses Data Store" .


#################################################################
#    Data properties
#################################################################

###  http://www.semanticweb.org/obrienchrist/ontologies/2026/5/Certificate-of-Employment-Ontology/hasDurationMinutes
<http://www.semanticweb.org/obrienchrist/ontologies/2026/5/Certificate-of-Employment-Ontology/hasDurationMinutes> rdf:type owl:DatatypeProperty ;
                                                                                                                  rdfs:domain <http://www.semanticweb.org/obrienchrist/ontologies/2026/5/Certificate-of-Employment-Ontology/UserTask> ;
                                                                                                                  rdfs:range xsd:decimal ;
                                                                                                                  rdfs:comment "Total empirically measured duration of this process step in decimal minutes (Raw Processing Time). Values are converted from the MM:SS entries in CoE_RPT.csv (RPT column) using total_seconds / 60, rounded to two decimals. Only leaf classes corresponding to a CSV row carry a value. The sum of these durations yields the RPT for the whole process, used to calculate the Flow Factor (FF)." ;
                                                                                                                  rdfs:label "has Duration in Minutes" .


